{
  "manifest_version": 3,
  "name": "BEP Event Autofill",
  "version": "1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:4150/*",
        "*://*.funcheap.com/*",
        "*://*.visitoakland.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
